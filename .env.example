# ===== Qdrant (vector store) =====
QDRANT_API_KEY=your_api_key_here
QDRANT_URL=https://your_qdrant_url_here
QDRANT_CLUSTER=your_cluster_name_here
QDRANT_COLLECTION=your_collection_name_here

# ===== Embedding model =====
EMBEDDING_BACKEND=e5              # e5 | harrier
EMBEDDING_MODEL=intfloat/multilingual-e5-large # microsoft/harrier-oss-v1
EMBEDDING_DEVICE=cpu          # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=32

# ===== Chunking (character-based) =====
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ===== PDF / OCR (PaddleOCR) =====
ENABLE_OCR=true
OCR_LANGUAGE=en               # PaddleOCR codes: en | ch | tr | german | french | japan | korean ...
OCR_DPI=200
OCR_USE_ANGLE_CLS=true        # auto-rotate sideways/upside-down text
MIN_CHARS_FOR_OCR_SKIP=50

# ===== LLM (Ollama, local) =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=8192
OLLAMA_TIMEOUT=120

# ===== Retrieval =====
RETRIEVAL_TOP_K=6
# RETRIEVAL_SCORE_THRESHOLD=0.55   # uncomment to drop weak hits

# ===== Paths =====
DATA_DIR=data

# ===== Logging =====
# DEBUG | INFO | WARNING | ERROR  — read by src/utils/log.setup_logging()
LOG_LEVEL=INFO
