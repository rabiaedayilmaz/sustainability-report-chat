{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "uid": "rag-main",
  "title": "RAG — Sustainability Report Chat",
  "tags": ["rag", "ntt-data"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "/ask success rate (5m)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum(rate(rag_ask_total{status=\"success\"}[5m])) / clamp_min(sum(rate(rag_ask_total[5m])), 1e-12)",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 0.8},
            {"color": "green", "value": 0.95}
          ]}
        }, "overrides": []
      },
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "/ask total",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rag_ask_total)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Chunks indexed (lifetime)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rag_chunks_indexed_total", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Service uptime",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "time() - process_start_time_seconds{job=\"rag-api\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 0}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "/ask rate by outcome",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (status) (rate(rag_ask_total[5m]))",
        "legendFormat": "{{status}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Hits returned per query",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (le) (rate(rag_hits_returned_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(rag_hits_returned_bucket[5m])))", "legendFormat": "p95", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Retrieval latency (Qdrant + query embed)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.5,  sum by (le) (rate(rag_retrieval_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(rag_retrieval_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(rag_retrieval_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "LLM latency (Ollama generate)",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.5,  sum by (le) (rate(rag_llm_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(rag_llm_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(rag_llm_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Embedding latency by kind",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(rag_embed_seconds_bucket[5m])))",
        "legendFormat": "{{kind}} p95",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "HTTP requests by handler/status",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (handler, status) (rate(http_requests_total{job=\"rag-api\"}[5m]))",
        "legendFormat": "{{handler}} {{status}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 40,
      "type": "table",
      "title": "Index identity (rag_index_info)",
      "gridPos": {"x": 0, "y": 28, "w": 24, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "rag_index_info",
        "instant": true,
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true},
      "transformations": [
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "__name__": true, "Value": true, "instance": true, "job": true, "service": true, "component": true},
          "renameByName": {
            "embedding_model": "Embedding model",
            "embedding_dim": "Dim",
            "schema_version": "Schema",
            "fingerprint": "Fingerprint"
          }
        }}
      ]
    }
  ]
}
